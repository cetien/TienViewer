<UserControl x:Class="TienViewer.Viewers.UnsupportedViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>

        <!-- ── 상단: 메타 + 버튼 ── -->
        <Border DockPanel.Dock="Top"
                Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="0,0,0,1"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 파일 메타 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="fileName: " FontWeight="SemiBold" Foreground="#555"/>
                        <TextBlock x:Name="FileNameText" Foreground="#222"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="fileSize: " FontWeight="SemiBold" Foreground="#555"/>
                        <TextBlock x:Name="FileSizeText" Foreground="#222"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="created: " FontWeight="SemiBold" Foreground="#555"/>
                        <TextBlock x:Name="FileCreatedText" Foreground="#222"/>
                    </StackPanel>
                </StackPanel>

                <!-- 버튼 행 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">

                    <!-- ZIP 전용 Mount -->
                    <Button x:Name="MountButton"
                            Content="📂 Mount"
                            Click="Mount_Click"
                            Padding="12,6" FontSize="12"
                            Visibility="Collapsed"
                            Margin="0,0,6,0"/>

                    <!-- 외부 뷰어 -->
                    <Button x:Name="OpenExternalButton"
                            Content="External Viewer"
                            Click="OpenExternal_Click"
                            Padding="12,6" FontSize="12"
                            Margin="0,0,6,0"/>

                    <!-- 삭제 -->
                    <Button x:Name="DeleteButton"
                            Content="Delete"
                            Click="Delete_Click"
                            Padding="12,6" FontSize="12"
                            Foreground="White" Background="#C0392B"
                            BorderBrush="#A93226"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 하단: Hex View ── -->
        <Grid DockPanel.Dock="Bottom">

            <!-- 열 헤더 -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 행 -->
            <Border Grid.Row="0" Background="#2C2C2C" Padding="8,4">
                <TextBlock FontFamily="Consolas,Courier New,monospace"
                           FontSize="12" Foreground="#888"
                           Text="Offset    00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F   ASCII"/>
            </Border>

            <!-- Hex 행 목록 -->
            <ScrollViewer Grid.Row="1" Background="#1E1E1E"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="HexLines" Padding="8,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Consolas,Courier New,monospace"
                                       FontSize="12" Foreground="#D4D4D4"
                                       Text="{Binding}"
                                       Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </DockPanel>
</UserControl>
