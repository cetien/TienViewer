<UserControl x:Class="TienViewer.Viewers.HexViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        외부 ScrollViewer : 뷰어 전체 스크롤
        내부 Border       : width 1000, 중앙 정렬, 상하 margin 50
    -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  Background="#1E1E1E">
        <Border Width="1000"
                HorizontalAlignment="Center"
                Margin="0,50,0,50">
            <StackPanel>

                <!-- 열 헤더 -->
                <Border Background="#2C2C2C"
                        Padding="8,6"
                        CornerRadius="4,4,0,0">
                    <TextBlock FontFamily="Consolas,Courier New,monospace"
                               FontSize="12"
                               Foreground="#888"
                               Text="Offset    00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F   ASCII"/>
                </Border>

                <!-- Hex 행 목록 -->
                <Border Background="#1E1E1E"
                        Padding="8,4"
                        CornerRadius="0,0,4,4">
                    <ItemsControl x:Name="HexLines">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas,Courier New,monospace"
                                           FontSize="12"
                                           Foreground="#D4D4D4"
                                           Text="{Binding}"
                                           Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
