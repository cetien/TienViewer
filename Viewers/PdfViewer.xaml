<UserControl x:Class="TienViewer.Viewers.PdfViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button x:Name="BtnPrev" Content="◀ 이전" Click="BtnPrev_Click" Margin="2" Padding="6,2"/>
            <TextBlock x:Name="PageInfo" VerticalAlignment="Center" Margin="8,0"/>
            <Button x:Name="BtnNext" Content="다음 ▶" Click="BtnNext_Click" Margin="2" Padding="6,2"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Image x:Name="PageImage" Stretch="Uniform"/>
        </ScrollViewer>
    </Grid>
</UserControl>