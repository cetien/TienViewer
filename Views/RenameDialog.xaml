<Window x:Class="TienViewer.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이름 바꾸기" Height="130" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="새 이름:" Foreground="#AAAAAA" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox"
                 Background="#2A2A2A" Foreground="White"
                 BorderBrush="#555555" Padding="6,4"
                 KeyDown="NameBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="확인"  Width="70" Margin="0,0,8,0" Click="Ok_Click"
                    Background="#336699" Foreground="White" BorderThickness="0" Padding="0,5"/>
            <Button Content="취소"  Width="70" Click="Cancel_Click"
                    Background="#3A3A3A" Foreground="#CCCCCC" BorderThickness="0" Padding="0,5"/>
        </StackPanel>
    </StackPanel>
</Window>
