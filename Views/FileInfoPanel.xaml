<UserControl x:Class="TienViewer.Views.FileInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260">

    <UserControl.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,6,0,1"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                                <Setter Property="BorderBrush" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#663333"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#1A1A1A"
            BorderBrush="#333333"
            BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="14,12">

                <!-- 파일명 헤더 -->
                <TextBlock x:Name="FileNameText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextWrapping="Wrap"
                           TextTrimming="None"/>

                <Separator Margin="0,8" Background="#333333"/>

                <!-- 파일 정보 섹션 -->
                <TextBlock Text="파일 정보" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="크기" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="FileSizeText" Style="{StaticResource ValueStyle}"/>

                <TextBlock Text="수정일" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="FileModifiedText" Style="{StaticResource ValueStyle}"/>

                <TextBlock Text="경로" Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="FilePathText" Style="{StaticResource ValueStyle}"
                           Cursor="Hand" TextDecorations="Underline"
                           MouseLeftButtonUp="FilePath_Click"/>

                <!-- 뷰어 속성 섹션 -->
                <TextBlock Text="속성" Style="{StaticResource SectionHeader}"/>
                <StackPanel x:Name="ViewerPropsPanel"/>

                <Separator Margin="0,12" Background="#333333"/>

                <!-- 작업 버튼 -->
                <TextBlock Text="작업" Style="{StaticResource SectionHeader}"/>

                <Button x:Name="BtnExplorer" Content="📂  탐색기에서 열기"
                        Style="{StaticResource ActionButton}"
                        Click="BtnExplorer_Click"/>

                <Button x:Name="BtnRename" Content="✏️  이름 바꾸기"
                        Style="{StaticResource ActionButton}"
                        Click="BtnRename_Click"/>

                <Button x:Name="BtnMove" Content="📋  이동..."
                        Style="{StaticResource ActionButton}"
                        Click="BtnMove_Click"/>

                <Button x:Name="BtnDelete" Content="🗑️  휴지통으로 삭제"
                        Style="{StaticResource DangerButton}"
                        Click="BtnDelete_Click"/>

                <Separator Margin="0,12" Background="#333333"/>

                <Button x:Name="BtnExit" Content="⏻  앱 종료"
                        Style="{StaticResource DangerButton}"
                        Click="BtnExit_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
